{
  "schema_name": "psychopathologischer_befund",
  "version": "2.0",
  "language": "de",
  "doc_type": "befund_schema",
  "description": "Strukturschema fuer den psychopathologischen Befund - kompakte Darstellung",
  "format": {
    "style": "Begriff: Text; Naechster-Begriff: Text;",
    "separator": ";",
    "no_paragraphs": true,
    "inline_format": true
  },
  "begriffe": [
    "Bewusstsein",
    "Orientierung",
    "Kognition",
    "Denken formal und inhaltlich",
    "Aengste",
    "Wahrnehmung",
    "Ich-Stoerungen",
    "Affekt",
    "Antrieb",
    "zirkadiane Besonderheiten",
    "Suizidalitaet"
  ],
  "rules": {
    "extract_from_patient_data": true,
    "descriptive_not_interpretive": true,
    "style": "sachlich, objektiv, befundorientiert"
  }
}
