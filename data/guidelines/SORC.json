{
  "schema_name": "sorc_subschema_vt",
  "version": "2.0",
  "language": "de",
  "model_type": "verhaltenstherapeutisches_bedingungsmodell",
  "format": {
    "style": "Komponente: Unterkomponente: Text; Naechste-Unterkomponente: Text",
    "separator": ";",
    "line_breaks_between_components": true
  },
  "rules": {
    "all_components_required": true,
    "no_merging_of_components": true,
    "descriptive_not_interpretive": true,
    "style": "sachlich, funktional, gutachterlich"
  },
  "components": {
    "S": {
      "label": "Stimulus",
      "format": "S: Extern: Text; Intern: Text",
      "items": ["Extern", "Intern"]
    },
    "O": {
      "label": "Organismus",
      "format": "O: Genetik: Text; Somatik: Text; Erziehung: Text; Persoenlichkeit: Text; Ueberlebensregel: Text",
      "items": ["Genetik", "Somatik", "Erziehung", "Persoenlichkeit", "Ueberlebensregel"]
    },
    "R": {
      "label": "Response",
      "format": "R: Gedanken: Text; Gefuehle: Text; Koerperreaktionen: Text; Verhalten: Text",
      "items": ["Gedanken", "Gefuehle", "Koerperreaktionen", "Verhalten"]
    },
    "C": {
      "label": "Consequences",
      "format_per_line": true,
      "items": ["C+", "C-", "C+/", "C-/"]
    }
  }
}
